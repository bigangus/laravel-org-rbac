{
    "name": "zhanghongfei/laravel-org-rbac",
    "version": "0.7.0",
    "description": "Laravel 12 / 13 greenfield multi-tenant hierarchical RBAC (Redis cache, audit-friendly logs): tenant tree, roles, permissions",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "zhanghongfei"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^12.0|^13.0",
        "illuminate/database": "^12.0|^13.0",
        "illuminate/http": "^12.0|^13.0",
        "illuminate/contracts": "^12.0|^13.0",
        "illuminate/routing": "^12.0|^13.0",
        "illuminate/console": "^12.0|^13.0",
        "illuminate/events": "^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.18",
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^10.0|^11.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0|^12.0"
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse --memory-limit=512M",
        "pint": "pint"
    },
    "autoload": {
        "psr-4": {
            "Zhanghongfei\\OrgRbac\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Zhanghongfei\\OrgRbac\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Zhanghongfei\\OrgRbac\\OrgRbacServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
